class Book:
    def __init__(self, title):
        self.title = title
        self.issued = False

class Member:
    def __init__(self, name):
        self.name = name

class Library:
    def __init__(self):
        self.books = []

    def add_book(self):
        title = input("Enter book title: ")
        self.books.append(Book(title))
        print("Book added successfully")

    def lend_book(self):
        title = input("Enter book title to lend: ")
        for b in self.books:
            if b.title == title and not b.issued:
                b.issued = True
                print("Book issued")
                return
        print("Book not available")

    def return_book(self):
        title = input("Enter book title to return: ")
        for b in self.books:
            if b.title == title:
                b.issued = False
                print("Book returned")
                return
        print("Book not found")

    def display_books(self):
        print("Books in library:")
        for b in self.books:
            status = "Issued" if b.issued else "Available"
            print(b.title, "-", status)

lib = Library()

while True:
    print("\n1.Add Book")
    print("2.Lend Book")
    print("3.Return Book")
    print("4.Display Books")
    print("5.Exit")

    ch = int(input("Enter choice: "))

    if ch == 1:
        lib.add_book()

    elif ch == 2:
        lib.lend_book()

    elif ch == 3:
        lib.return_book()

    elif ch == 4:
        lib.display_books()

    elif ch == 5:
        break

    else:
        print("Invalid choice")